# Supernumerario Configuration (.env.example)

# Database Configuration
DB_HOST=localhost
DB_NAME=supernumerario
DB_USER=root
DB_PASS=secret

# Mail Configuration
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=null
MAIL_PASS=null
MAIL_FROM_ADDRESS=noreply@mascargo.com
MAIL_FROM_NAME="Mas Cargo Ticketing"
MAIL_DRIVER=mail  # Use 'mail' for PHP mail() or 'smtp' for PHPMailer SMTP
DB_CHARSET=utf8mb4

# Application Configuration
APP_ENV=production
APP_URL=http://yourdomain.com
