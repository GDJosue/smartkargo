# Mas Cargo MVC Routing .htaccess

# Disable directory listing
Options -Indexes

# Security: Block access to sensitive files
<FilesMatch "^(config\.php|database\.sql|composer\.json|package\.json|package-lock\.json|\.env|\.git.*)$">
    order allow,deny
    deny from all
</FilesMatch>

# Routing Engine
RewriteEngine On
RewriteBase /

# Allow access to existing files and directories (assets like css, js, img)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to index.php
RewriteRule ^(.*)$ index.php [L,QSA]
